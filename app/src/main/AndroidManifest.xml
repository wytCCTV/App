<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!--     申明权限列表 -->
    <!-- 允许应用访问网络状态 -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" /> <!-- 允许应用控制震动 -->
    <uses-permission android:name="android.permission.VIBRATE" /> <!-- 允许应用程序发现和控制蓝牙，管理本地蓝牙链接 -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" /> <!-- 允许应用程序连接到已配对的蓝牙设备或者进行蓝牙通信 -->
    <uses-permission android:name="android.permission.BLUETOOTH" /> <!-- 允许应用挂载和卸载可移动文件系统，通常用于访问外部存储设备 -->
    <uses-permission
        android:name="android.permission.MOUNT_UNMOUNT_FILESYSTEMS"
        tools:ignore="ProtectedPermissions" /> <!-- 允许应用写入外部存储（如SD卡）的文件，这样应用可以保存数据到设备的持久存储中 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" /> <!-- 允许应用访问精确的位置信息，通常使用 GPS 或其他定位服务来获取。 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" /> <!-- 允许应用访问大致的位置信息，使用网络或其他源来确定用户大致的位置 -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" /> <!-- 允许应用访问互联网 -->
    <uses-permission android:name="android.permission.INTERNET" /> <!-- 允许应用访问 Wi-Fi 网络状态信息，如连接状态、SSID等 -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" /> <!-- 允许应用改变 Wi-Fi 连接状态，如打开或关闭 Wi-Fi -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" /> <!-- 允许应用在屏幕关闭后继续保持设备唤醒状态，确保后台服务或任务能够继续运行。 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" /> <!-- 振动器权限 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication"
        tools:targetApi="31">



        <activity
            android:name=".DeviceControlActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>